{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/style.css",
      "dest": "/style.css",
      "headers": { "content-type": "text/css; charset=utf-8" }
    },
    {
      "src": "/app.js",
      "dest": "/app.js",
      "headers": { "content-type": "application/javascript; charset=utf-8" }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
